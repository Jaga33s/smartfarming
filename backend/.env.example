# PostgreSQL connection string
# Locally:      postgresql://postgres:postgres@localhost:5432/smart_farming
# On Render:    use the "Internal Database URL" from your Render Postgres instance
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_farming

# JWT
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://your-frontend.onrender.com
